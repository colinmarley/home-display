# Google Calendar — Settings → "Secret address in iCal format"
GOOGLE_ICAL_URL=https://calendar.google.com/calendar/ical/YOUR_CALENDAR_ID/private-XXXX/basic.ics

# Apple iCloud — iCloud.com → Calendar → share icon → copy link (ends in .ics)
APPLE_ICAL_URL=https://p01-caldav.icloud.com/published/2/YOUR_CALENDAR_HASH

# Weather (Open-Meteo, no API key needed)
WEATHER_LAT=37.7749
WEATHER_LON=-122.4194

# Immich — Profile → Account Settings → API Keys
IMMICH_BASE_URL=http://YOUR_IMMICH_HOST:2283
IMMICH_API_KEY=your_immich_api_key_here
# Get album ID: Immich web UI → open album → copy UUID from URL
IMMICH_ALBUM_ID=your_album_uuid_here

# Display behaviour
IDLE_TIMEOUT_MINUTES=5
PHOTO_INTERVAL_SECONDS=30
